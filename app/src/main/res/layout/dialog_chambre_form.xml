<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/screen_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_panel"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="18dp">

            <TextView
                style="@style/TextAppearance.HotelManager.FormTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/add_room"
                android:textColor="@color/white" />

            <TextView
                style="@style/TextAppearance.HotelManager.FormBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/form_required_note"
                android:textColor="@color/header_text_muted" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        style="@style/TextAppearance.HotelManager.SectionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_room_setup" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutRoomNumber"
                        style="@style/Widget.HotelManager.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/hint_room_number">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editRoomNumber"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:inputType="textCapCharacters"
                            android:textColor="@color/input_text"
                            android:textSize="@dimen/text_size_base" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutRoomType"
                        style="@style/Widget.HotelManager.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="@string/hint_room_type"
                        app:endIconMode="dropdown_menu">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/inputRoomType"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:inputType="none"
                            android:textColor="@color/input_text"
                            android:textSize="@dimen/text_size_base" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        style="@style/TextAppearance.HotelManager.SectionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_room_pricing" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutRoomPrice"
                        style="@style/Widget.HotelManager.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/hint_room_price"
                        app:prefixText="FBU ">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editRoomPrice"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:inputType="numberDecimal"
                            android:textColor="@color/input_text"
                            android:textSize="@dimen/text_size_base" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutRoomCapacity"
                        style="@style/Widget.HotelManager.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:hint="@string/hint_room_capacity"
                        app:suffixText=" pers.">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editRoomCapacity"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:inputType="number"
                            android:textColor="@color/input_text"
                            android:textSize="@dimen/text_size_base" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        style="@style/TextAppearance.HotelManager.SectionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_room_details" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutRoomEquipment"
                        style="@style/Widget.HotelManager.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/hint_room_equipment"
                        app:helperText="@string/helper_room_equipment">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editRoomEquipment"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapSentences|textMultiLine"
                            android:minLines="3"
                            android:textColor="@color/input_text"
                            android:textSize="@dimen/text_size_base" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchRoomAvailable"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:checked="true"
                        android:minHeight="48dp"
                        android:paddingVertical="8dp"
                        android:text="@string/hint_room_available"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_base"
                        app:thumbTint="@color/accent_blue"
                        app:trackTint="@color/input_border" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonSaveRoom"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="16dp"
                android:text="@string/save_room"
                android:textSize="@dimen/text_size_base"
                android:textStyle="bold"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
