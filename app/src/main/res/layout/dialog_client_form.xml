<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_client"
            style="@style/TextAppearance.HotelManager.FormTitle" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/client_form_intro"
            style="@style/TextAppearance.HotelManager.FormBody" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/form_required_note"
            android:textColor="@color/accent_blue"
            android:textSize="11sp"
            android:textStyle="bold" />

        <EditText
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="0dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/section_identity"
            style="@style/TextAppearance.HotelManager.SectionTitle" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutClientNom"
            style="@style/Widget.HotelManager.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/hint_nom">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editClientNom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutClientPrenom"
            style="@style/Widget.HotelManager.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/hint_prenom">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editClientPrenom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/section_contact"
            style="@style/TextAppearance.HotelManager.SectionTitle" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutClientEmail"
            style="@style/Widget.HotelManager.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/hint_email"
            app:helperText="Optionnel">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editClientEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutClientTelephone"
            style="@style/Widget.HotelManager.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/hint_telephone"
            app:helperText="Exemple : +243 ou +250">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editClientTelephone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="phone"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutClientAdresse"
            style="@style/Widget.HotelManager.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/hint_adresse"
            app:helperText="Optionnel">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editClientAdresse"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPostalAddress"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/section_documents"
            style="@style/TextAppearance.HotelManager.SectionTitle" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutClientPassport"
            style="@style/Widget.HotelManager.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/hint_passport"
            app:helperText="Reference unique du voyageur">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editClientPassport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutClientBirthDate"
            style="@style/Widget.HotelManager.TextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/hint_birth_date"
            app:helperText="@string/helper_birth_date">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editClientBirthDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:cursorVisible="false"
                android:focusable="false"
                android:inputType="none"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/buttonSaveClient"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_button_primary"
            android:text="@string/save_client"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="13sp" />
    </LinearLayout>
</ScrollView>
