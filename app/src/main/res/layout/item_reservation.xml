<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:strokeColor="@color/card_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textReservationClient"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textReservationRoom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/textReservationStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge_green"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:textColor="@color/badge_green_text"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/textReservationDates"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/textReservationTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/accent_blue"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/buttonReservationServices"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:background="@drawable/bg_button_secondary"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:minWidth="76dp"
                android:text="@string/action_services"
                android:textColor="@color/accent_blue"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/buttonReservationInvoice"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_button_secondary"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:minWidth="76dp"
                android:text="@string/action_invoice"
                android:textColor="@color/accent_blue"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/buttonCancelReservation"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_tag"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:minWidth="76dp"
                android:text="@string/action_cancel"
                android:textColor="@color/badge_gray_text"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/buttonDeleteReservation"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_badge_red"
                android:foreground="?attr/selectableItemBackground"
                android:gravity="center"
                android:minWidth="76dp"
                android:text="@string/action_delete"
                android:textColor="@color/badge_red_text"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
